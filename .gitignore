# =========================

# 🚀 Node.js .gitignore

# =========================

# 📦 Dependencies

node_modules/

# 🔐 Environment variables (VERY IMPORTANT)

.env
.env.*
!.env.example

# 🧾 Logs

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# 🗄️ Runtime files

pids/
*.pid
*.seed
*.pid.lock

# 📁 Build / Output

dist/
build/
out/

# 🧪 Coverage

coverage/
.nyc_output/

# 🧰 IDE / Editor

.vscode/
.idea/
*.swp
*.swo

# 🧹 OS files

.DS_Store
Thumbs.db

# 🐳 Docker (optional)

.dockerignore

# 🗃️ Database files (local only)

*.sqlite
*.db

# 🔑 Keys / Secrets

*.pem
*.key

# 📂 Temp / cache

tmp/
temp/
.cache/

# 📦 Uploads (if any)

uploads/
